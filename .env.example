# Copy to .env and fill in values before running locally.
# Never commit .env to version control.

# App
APP_ENV=development
PORT=8082

# GCP / Vertex AI
# Auth via Application Default Credentials — no API key needed.
# Run: gcloud auth application-default login
GCP_PROJECT=ms7285-ieor4576-proj03
GCP_LOCATION=us-central1
LLM_MODEL=google/gemini-2.5-flash

# Local Postgres with pgvector
# Install pgvector: https://github.com/pgvector/pgvector
# createdb cruisewise && psql cruisewise -f backend/db/migrations/001_initial.sql
DATABASE_URL=postgresql://localhost/cruisewise

# CORS — comma-separated, no trailing slash
ALLOWED_ORIGINS=http://localhost:8082,http://localhost:3000

# Apify — cruise inventory scraping
# Get your token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_api_token_here
